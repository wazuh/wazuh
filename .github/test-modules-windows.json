{
  "modules": [
    {
      "name": "fim",
      "pytest_target": "test_fim\\",
      "tiers": ["0", "1"],
      "exclude": ["test_fim\\test_files\\test_basic_usage\\test_rename.py"],
      "start_service": true,
      "paths": [
        "src/config/src/syscheck-config.c",
        "src/config/include/syscheck-config.h",
        "src/syscheckd/**",
        "src/Makefile",
        "tests/integration/conftest.py",
        "tests/integration/test_fim/**"
      ]
    },
    {
      "name": "logcollector",
      "pytest_target": "test_logcollector\\",
      "paths": [
        "src/config/src/localfile-config.c",
        "src/config/include/localfile-config.h",
        "src/logcollector/**",
        "src/Makefile",
        "tests/integration/conftest.py",
        "tests/integration/test_logcollector/**"
      ]
    }
  ]
}
