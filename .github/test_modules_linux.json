{
  "modules": [
    {
      "name": "agentd",
      "pytest_target": "test_agentd/",
      "tiers": ["0 1"],
      "timeout_minutes": 120,
      "paths": [
        ".github/workflows/5_testintegration_linux-integration-tests.yml",
        ".github/test_modules_linux.json",
        "src/client-agent/**",
        "src/config/src/buffer-config.c",
        "src/config/src/client-config.c",
        "src/config/include/client-config.h",
        "src/Makefile",
        "tests/integration/conftest.py",
        "tests/integration/test_agentd/**"
      ]
    },
    {
      "name": "aws",
      "pytest_target": "test_aws/",
      "tiers": ["0 1"],
      "timeout_minutes": 120,
      "setup_aws_credentials": true,
      "paths": [
        ".github/workflows/5_testintegration_linux-integration-tests.yml",
        ".github/test_modules_linux.json",
        "src/config/src/wmodules-aws.c",
        "src/wazuh_modules/src/wm_aws.c",
        "src/wazuh_modules/src/wm_aws.h",
        "wodles/aws/wazuh_integration.py",
        "src/Makefile",
        "tests/integration/conftest.py",
        "tests/integration/test_aws/**"
      ]
    },
    {
      "name": "aws_parser",
