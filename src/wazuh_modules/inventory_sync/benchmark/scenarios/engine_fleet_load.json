{
  "name": "engine_fleet_load",
  "description": "50 agents, each runs engine + fim + sca + syscollector. Engine uses both terminators (whichever-first): stops when all three inventory lanes finish on that specific agent, with a 60s safety upper bound. Validates Mode B at scale and confirms each agent's counter is independent.",
  "lanes": {
    "engine": [
      {
        "engine": "sample_payloads/engine/syslog.log",
        "location": "syslog",
        "max_eps": 200,
        "loop": true,
        "duration": 60.0,
        "run_while_siblings_active": true
      }
    ],
    "fim": [
      {
        "dump": "sample_payloads/fim/ubuntu22_fim_first_sync.json",
        "max_eps": 75,
        "use_databatch": true,
        "ack_timeout_retry": 0,
        "offline_retry": 0,
        "offline_retry_delay": 2.0,
        "start_ack_timeout": 5,
        "end_ack_processing_timeout": 10,
        "end_ack_timeout": 120
      }
    ],
    "sca": [
      {
        "dump": "sample_payloads/dump-sca/session_sca_ubuntu.json",
        "max_eps": 75,
        "use_databatch": true,
        "ack_timeout_retry": 0,
        "offline_retry": 0,
        "offline_retry_delay": 2.0,
        "start_ack_timeout": 5,
        "end_ack_processing_timeout": 10,
        "end_ack_timeout": 120
      }
    ],
    "syscollector": [
      {
        "dump": "sample_payloads/dump-syscollector/session_syscollector_sync_debian10.json",
        "max_eps": 75,
        "use_databatch": true,
        "ack_timeout_retry": 0,
        "offline_retry": 0,
        "offline_retry_delay": 2.0,
        "start_ack_timeout": 5,
        "end_ack_processing_timeout": 10,
        "end_ack_timeout": 120
      }
    ]
  },
  "fleets": [
    { "name": "linux", "agents": 50, "lanes": ["engine", "fim", "sca", "syscollector"] }
  ],
  "parallel_agents": 0,
  "repeat_until": 0,
  "drain_timeout": 30,
  "post_run_grace": 10
}
