{
  "name": "engine_duration_AND_siblings",
  "description": "Engine has BOTH duration=30 AND run_while_siblings_active. Inventory (Ubuntu SCA ~207 items @ 75 EPS ~= 3s) finishes well before 30s. Whichever-first composition: siblings must win.",
  "defaults": {
    "session_type": "delta",
    "max_eps": 75,
    "use_databatch": true,
    "ack_timeout_retry": 0
  },
  "lanes": {
    "engine": [
      {
        "engine": "sample_payloads/engine/syslog.log",
        "location": "syslog",
        "max_eps": 500,
        "loop": true,
        "duration": 30.0,
        "run_while_siblings_active": true
      }
    ],
    "sca": [
      { "dump": "sample_payloads/dump-sca/session_sca_ubuntu.json" }
    ]
  },
  "fleets": [
    { "name": "single", "agents": 1, "lanes": ["engine", "sca"] }
  ],
  "parallel_agents": 0,
  "repeat_until": 0,
  "drain_timeout": 3
}
