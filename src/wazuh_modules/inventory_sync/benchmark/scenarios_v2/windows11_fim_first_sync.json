{
  "name": "windows11_fim_first_sync",
  "description": "Replay a Windows 11 FIM first sync captured from Inventory Sync FlatBuffer dumps.",
  "agent_configs": [
    {
      "payload_dump": "sample_payloads/fim/windows11_fim_first_sync.json",
      "session_type": "delta",
      "max_eps": 75,
      "use_databatch": true,
      "retransmit": true
    }
  ],
  "behavior": {
    "total_agents": 1,
    "parallel_agents": 0,
    "repeat_until": 0,
    "drain_timeout": 30
  }
}
