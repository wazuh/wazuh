{
  "name": "SCASingleWindowsStart",
  "description": "Windows server initial sync of default SCA policies",
  "agent_configs": [
    {
      "payload_dump": "sample_payloads/dump-sca/session_sca_windows.json",
      "session_type": "delta",
      "max_eps": 75,
      "use_databatch": true,
      "retransmit": true
    }
  ],
  "behavior": {
    "total_agents": 1,
    "parallel_agents": 1,
    "repeat_until": 0,
    "drain_timeout": 90
  }
}
